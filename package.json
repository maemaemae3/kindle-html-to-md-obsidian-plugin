{
	"name": "kindle-html-to-md",
	"version": "1.0.0",
	"description": "Import Kindle HTML highlights and convert them to Obsidian Markdown notes.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^16.11.6",
		"esbuild": "0.17.3",
		"eslint-plugin-obsidianmd": "^0.1.9",
		"globals": "^17.4.0",
		"jiti": "^2.6.1",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.1"
	}
}
